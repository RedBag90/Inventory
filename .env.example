# ─── Database ────────────────────────────────────────────────────────────────
# Local Docker: both URLs point to the same instance.
# Production (Supabase): DATABASE_URL = pooled PgBouncer URL, DIRECT_DATABASE_URL = direct URL.
DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"
DIRECT_DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── SMTP (join-request email notifications) ─────────────────────────────────
# Use a real SMTP provider — smtp.supabase.co does NOT exist.
# Recommended providers:
#   Resend:    smtp.resend.com    port 465  user=resend       pass=<api-key>
#   SendGrid:  smtp.sendgrid.net  port 587  user=apikey       pass=<api-key>
#   Mailgun:   smtp.mailgun.org   port 587  user=<mailgun-user> pass=<pass>
#
# NOTE: This is for our app's join-request emails (nodemailer).
#       Supabase Auth emails (password reset etc.) are configured separately
#       in the Supabase Dashboard → Authentication → SMTP Settings.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
SMTP_FROM="Flohmarkt-Olympiade <noreply@your-domain.com>"

# ─── Weekly Digest Cron ──────────────────────────────────────────────────────
# Protects /api/cron/weekly-digest. Vercel sets Authorization: Bearer <CRON_SECRET> automatically.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret
# Public URL of the app — used in digest email links
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ─── Database ────────────────────────────────────────────────────────────────
# Local Docker: both URLs point to the same instance.
# Production (Supabase): DATABASE_URL = pooled PgBouncer URL, DIRECT_DATABASE_URL = direct URL.
DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"
DIRECT_DATABASE_URL="postgresql://inventory:inventory@localhost:5432/inventory?schema=public"

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── SMTP (join-request email notifications) ─────────────────────────────────
# Supabase SMTP: Settings → Auth → SMTP Settings (enable custom SMTP)
# Host: smtp.supabase.co  Port: 587  User: <project-ref>  Pass: <smtp-password>
SMTP_HOST=smtp.supabase.co
SMTP_PORT=587
SMTP_USER=your-project-ref
SMTP_PASS=your-smtp-password
SMTP_FROM="Flohmarkt-Olympiade <noreply@your-domain.com>"

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

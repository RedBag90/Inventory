generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // Pooled (PgBouncer) — runtime / Vercel
  directUrl = env("DIRECT_DATABASE_URL") // Direct — prisma migrate only
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                       String               @id @default(cuid())
  supabaseId               String               @unique
  email                    String               @unique
  displayName              String?
  role                     UserRole             @default(USER)
  isActive                 Boolean              @default(true)
  createdAt                DateTime             @default(now())
  tutorialCompletedAt      DateTime?
  items                    Item[]
  memberships              InstanceMembership[]
  createdOlympiads         OlympiadInstance[]
  joinRequests             JoinRequest[]        @relation("JoinRequests")
  resolvedRequests         JoinRequest[]        @relation("ResolvedRequests")
  instanceRequests         InstanceRequest[]    @relation("InstanceRequests")
  resolvedInstanceRequests InstanceRequest[]    @relation("ResolvedInstanceRequests")
}

model OlympiadInstance {
  id           String               @id @default(cuid())
  name         String
  description  String?
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  createdById  String
  inviteToken  String?              @unique
  joinCode     String?              @unique
  autoAccept   Boolean              @default(true)
  createdBy    User                 @relation(fields: [createdById], references: [id])
  memberships  InstanceMembership[]
  joinRequests JoinRequest[]

  @@index([createdById])
}

model JoinRequest {
  id           String            @id @default(cuid())
  userId       String
  instanceId   String
  status       JoinRequestStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  user         User              @relation("JoinRequests", fields: [userId], references: [id])
  instance     OlympiadInstance  @relation(fields: [instanceId], references: [id])
  resolvedBy   User?             @relation("ResolvedRequests", fields: [resolvedById], references: [id])

  @@index([instanceId, status])
  @@index([userId])
}

model InstanceMembership {
  id         String           @id @default(cuid())
  userId     String
  instanceId String
  joinedAt   DateTime         @default(now())
  memberRole MemberRole       @default(MEMBER)
  user       User             @relation(fields: [userId], references: [id])
  instance   OlympiadInstance @relation(fields: [instanceId], references: [id])

  @@unique([userId, instanceId])
  @@index([instanceId])
}

model Item {
  id               String           @id @default(cuid())
  name             String
  description      String?
  purchasePrice    Decimal          @db.Decimal(10, 2)
  purchasePlatform Platform
  purchasedAt      DateTime
  shippingCostIn   Decimal          @db.Decimal(10, 2) @default(0)
  repairCost       Decimal          @db.Decimal(10, 2) @default(0)
  status           ItemStatus       @default(IN_STOCK)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  sale             Sale?
  costs            AdditionalCost[]

  @@index([userId, status])
  @@index([userId, purchasedAt])
}

model Sale {
  id              String   @id @default(cuid())
  salePrice       Decimal  @db.Decimal(10, 2)
  salePlatform    Platform
  shippingCostOut Decimal  @db.Decimal(10, 2) @default(0)
  soldAt          DateTime
  createdAt       DateTime @default(now())
  itemId          String   @unique
  item            Item     @relation(fields: [itemId], references: [id])

  @@index([soldAt])
}

model AdditionalCost {
  id        String   @id @default(cuid())
  label     String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
}

model PendingEmailInvite {
  id         String   @id @default(cuid())
  email      String
  instanceId String
  createdAt  DateTime @default(now())

  @@unique([email, instanceId])
  @@index([email])
}

model InstanceRequest {
  id           String                @id @default(cuid())
  userId       String
  instanceName String
  description  String?
  status       InstanceRequestStatus @default(PENDING)
  createdAt    DateTime              @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  user         User                  @relation("InstanceRequests", fields: [userId], references: [id])
  resolvedBy   User?                 @relation("ResolvedInstanceRequests", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([userId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  MASTER_ADMIN
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum InstanceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MemberRole {
  MEMBER
  ADMIN
}

enum ItemStatus {
  IN_STOCK
  SOLD
}

enum Platform {
  KLEINANZEIGEN
  EBAY
  FACEBOOK
  OTHER
}
